COPY . .

ARG NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://medusa-backend-production-ee25.up.railway.app
ARG NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_eeeb73d333fd3caad7fb03ee54b028325f538454cb34e4a2368805a43bf45e61
ARG NEXT_PUBLIC_DEFAULT_REGION_ID=reg_01KMYRVGT2PVYZST2X0D7BGBJJ

ENV NEXT_PUBLIC_MEDUSA_BACKEND_URL=$NEXT_PUBLIC_MEDUSA_BACKEND_URL
ENV NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=$NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY
ENV NEXT_PUBLIC_DEFAULT_REGION_ID=$NEXT_PUBLIC_DEFAULT_REGION_ID

RUN npm run build

